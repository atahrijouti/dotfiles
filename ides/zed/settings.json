{
  "disable_ai": true,
  "proxy": "",
  "autosave": "on_window_change",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "project_panel": {
    "dock": "left",
    "hide_hidden": false,
  },
  "git_panel": {
    "dock": "left",
    "tree_view": false,
  },
  "diff_view_style": "unified",
  "icon_theme": "Material Icon Theme",
  "theme": {
    "mode": "system",
    "light": "My Cyan Light",
    "dark": "JetBrains New Dark",
  },
  "helix_mode": true,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 14,
  "buffer_font_weight": 500,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "tab_bar": {
    "show": false,
  },
  "show_wrap_guides": true,
  "toolbar": {},
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "inlay_hints": {
    "enabled": false,
  },
  "auto_update": false,
  "file_types": {
    "JSONC": ["~/AppData/Roaming/Zed/**/*.json"],
  },
  "terminal": {
    "shell": {
      "program": "nu",
    },
  },
  "format_on_save": "on",
  "lsp": {
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "rules": ["import/order"],
        },
      },
    },
  },
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
  },
}
